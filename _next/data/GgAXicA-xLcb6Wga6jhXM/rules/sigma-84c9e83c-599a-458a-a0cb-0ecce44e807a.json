{"pageProps":{"rule":{"metadata":{"updated_date":"2023-01-18T00:00:00.000Z","creation_date":"2023-01-18T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_disable_ufw.yml"},"rule":{"name":"Ufw Force Stop Using Ufw-Init","description":"Detects attempts to force stop the ufw using ufw-init","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1686","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection_init\": {\n    \"CommandLine|contains|all\": [\n      \"-ufw-init\",\n      \"force-stop\"\n    ]\n  },\n  \"selection_ufw\": {\n    \"CommandLine|contains|all\": [\n      \"ufw\",\n      \"disable\"\n    ]\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://blogs.blackberry.com/","https://twitter.com/Joseliyo_Jstnk/status/1620131033474822144"],"false_positives":["Network administrators"]}}},"__N_SSG":true}