{"pageProps":{"rule":{"metadata":{"updated_date":"2022-06-06T00:00:00.000Z","creation_date":"2022-06-06T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/web/webserver_generic/web_susp_windows_path_uri.yml"},"rule":{"name":"Suspicious Windows Strings In URI","description":"Detects suspicious Windows strings in URI which could indicate possible exfiltration or webshell communication","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","Tactic: Exfiltration","Technique: T1505.003","Domain: webserver","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"cs-uri-query|contains\": [\n      \"=C:/Users\",\n      \"=C:/Program%20Files\",\n      \"=C:/Windows\",\n      \"=C%3A%5CUsers\",\n      \"=C%3A%5CProgram%20Files\",\n      \"=C%3A%5CWindows\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://thedfirreport.com/2022/06/06/will-the-real-msiexec-please-stand-up-exploit-leads-to-data-exfiltration/"],"false_positives":["Legitimate application and websites that use windows paths in their URL"]}}},"__N_SSG":true}