{"pageProps":{"rule":{"metadata":{"updated_date":"2020-04-16T00:00:00.000Z","creation_date":"2020-04-16T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/cloud/aws/cloudtrail/aws_ec2_vm_export_failure.yml"},"rule":{"name":"AWS EC2 VM Export Failure","description":"An attempt to export an AWS EC2 instance has been detected. A VM Export might indicate an attempt to extract information from an instance.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Collection","Technique: T1005","Tactic: Exfiltration","Technique: T1537","OS: Aws","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"eventName\": \"CreateInstanceExportTask\",\n    \"eventSource\": \"ec2.amazonaws.com\"\n  },\n  \"filter1\": {\n    \"errorMessage|contains\": \"*\"\n  },\n  \"filter2\": {\n    \"errorCode|contains\": \"*\"\n  },\n  \"filter3\": {\n    \"responseElements|contains\": \"Failure\"\n  },\n  \"condition\": \"selection and not 1 of filter*\"\n}","reference":["https://docs.aws.amazon.com/vm-import/latest/userguide/vmexport.html#export-instance"],"false_positives":[]}}},"__N_SSG":true}