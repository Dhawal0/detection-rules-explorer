{"pageProps":{"rule":{"metadata":{"updated_date":"2022-12-28T00:00:00.000Z","creation_date":"2022-12-28T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_apt_shell_execution.yml"},"rule":{"name":"Shell Invocation via Apt - Linux","description":"Detects the use of the \"apt\" and \"apt-get\" commands to execute a shell or proxy commands.\nSuch behavior may be associated with privilege escalation, unauthorized command execution, or to break out from restricted environments.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1083","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": [\n      \"/apt\",\n      \"/apt-get\"\n    ],\n    \"CommandLine|contains\": \"APT::Update::Pre-Invoke::=\"\n  },\n  \"condition\": \"selection\"\n}","reference":["https://gtfobins.github.io/gtfobins/apt/","https://gtfobins.github.io/gtfobins/apt-get/"],"false_positives":["Unknown"]}}},"__N_SSG":true}