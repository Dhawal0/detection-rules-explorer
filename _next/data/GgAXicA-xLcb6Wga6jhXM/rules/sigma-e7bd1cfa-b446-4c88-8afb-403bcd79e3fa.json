{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-06T00:00:00.000Z","creation_date":"2020-10-06T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_system_network_discovery.yml"},"rule":{"name":"System Network Discovery - Linux","description":"Detects enumeration of local network configuration","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1016","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"informational","risk_score":5,"type":"sigma","language":"sigma","query":"{\n  \"selection_img\": {\n    \"Image|endswith\": [\n      \"/firewall-cmd\",\n      \"/ufw\",\n      \"/iptables\",\n      \"/netstat\",\n      \"/ss\",\n      \"/ip\",\n      \"/ifconfig\",\n      \"/systemd-resolve\",\n      \"/route\"\n    ]\n  },\n  \"selection_cli\": {\n    \"CommandLine|contains\": \"/etc/resolv.conf\"\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1016/T1016.md"],"false_positives":["Legitimate administration activities"]}}},"__N_SSG":true}