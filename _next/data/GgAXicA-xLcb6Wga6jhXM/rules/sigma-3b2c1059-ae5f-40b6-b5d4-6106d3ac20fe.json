{"pageProps":{"rule":{"metadata":{"updated_date":"2024-08-21T00:00:00.000Z","creation_date":"2024-08-21T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_chflags_hidden_flag.yml"},"rule":{"name":"Hidden Flag Set On File/Directory Via Chflags - MacOS","description":"Detects the execution of the \"chflags\" utility with the \"hidden\" flag, in order to hide files on MacOS.\nWhen a file or directory has this hidden flag set, it becomes invisible to the default file listing commands and in graphical file browsers.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1218","Technique: T1564.004","Technique: T1552.001","Technique: T1105","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": \"/chflags\",\n    \"CommandLine|contains\": \"hidden \"\n  },\n  \"condition\": \"selection\"\n}","reference":["https://www.sentinelone.com/labs/apt32-multi-stage-macos-trojan-innovates-on-crimeware-scripting-technique/","https://www.welivesecurity.com/2019/04/09/oceanlotus-macos-malware-update/","https://www.paloaltonetworks.com/content/dam/pan/en_US/assets/pdf/reports/Unit_42/unit42-wirelurker.pdf","https://ss64.com/mac/chflags.html"],"false_positives":["Legitimate usage of chflags by administrators and users."]}}},"__N_SSG":true}