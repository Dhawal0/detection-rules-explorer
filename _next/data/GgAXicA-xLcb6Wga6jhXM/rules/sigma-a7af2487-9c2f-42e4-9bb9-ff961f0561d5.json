{"pageProps":{"rule":{"metadata":{"updated_date":"2021-09-04T00:00:00.000Z","creation_date":"2021-09-04T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/auditd/lnx_auditd_audio_capture.yml"},"rule":{"name":"Audio Capture","description":"Detects attempts to record audio using the arecord and ecasound utilities.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Collection","Technique: T1123","OS: Linux","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_execve\": {\n    \"type\": \"EXECVE\",\n    \"a0\": \"arecord\",\n    \"a1\": \"-vv\",\n    \"a2\": \"-fdat\"\n  },\n  \"selection_syscall_memfd_create\": {\n    \"type\": \"SYSCALL\",\n    \"exe|endswith\": \"/ecasound\",\n    \"SYSCALL\": \"memfd_create\"\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://linux.die.net/man/1/arecord","https://linuxconfig.org/how-to-test-microphone-with-audio-linux-sound-architecture-alsa","https://manpages.debian.org/unstable/ecasound/ecasound.1.en.html","https://ecasound.seul.org/ecasound/Documentation/examples.html#fconversions"],"false_positives":["Unknown"]}}},"__N_SSG":true}