{"pageProps":{"rule":{"metadata":{"updated_date":"2021-09-10T00:00:00.000Z","creation_date":"2021-09-10T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/builtin/lnx_clear_syslog.yml"},"rule":{"name":"Commands to Clear or Remove the Syslog - Builtin","description":"Detects specific commands commonly used to remove or empty the syslog","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Impact","Technique: T1565.001","OS: Linux","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": [\n    \"rm /var/log/syslog\",\n    \"rm -r /var/log/syslog\",\n    \"rm -f /var/log/syslog\",\n    \"rm -rf /var/log/syslog\",\n    \"mv /var/log/syslog\",\n    \" >/var/log/syslog\",\n    \" > /var/log/syslog\"\n  ],\n  \"falsepositives\": [\n    \"/syslog.\"\n  ],\n  \"condition\": \"selection and not falsepositives\"\n}","reference":["https://www.virustotal.com/gui/file/fc614fb4bda24ae8ca2c44e812d12c0fab6dd7a097472a35dd12ded053ab8474"],"false_positives":["Log rotation"]}}},"__N_SSG":true}