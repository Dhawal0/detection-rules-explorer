{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-19T00:00:00.000Z","creation_date":"2020-10-19T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_file_and_directory_discovery.yml"},"rule":{"name":"File and Directory Discovery - MacOS","description":"Detects usage of system utilities to discover files and directories","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1083","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"informational","risk_score":5,"type":"sigma","language":"sigma","query":"{\n  \"select_file_with_asterisk\": {\n    \"Image\": \"/usr/bin/file\",\n    \"CommandLine|re\": \"(.){200,}\"\n  },\n  \"select_recursive_ls\": {\n    \"Image\": \"/bin/ls\",\n    \"CommandLine|contains\": \"-R\"\n  },\n  \"select_find_execution\": {\n    \"Image\": \"/usr/bin/find\"\n  },\n  \"select_mdfind_execution\": {\n    \"Image\": \"/usr/bin/mdfind\"\n  },\n  \"select_tree_execution|endswith\": {\n    \"Image\": \"/tree\"\n  },\n  \"condition\": \"1 of select*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1083/T1083.md"],"false_positives":["Legitimate activities"]}}},"__N_SSG":true}