{"pageProps":{"rule":{"metadata":{"updated_date":"2026-04-17T18:57:30.000Z","source_siem":"OpenSearch","source_siem_id":"opensearch","source_url":"https://github.com/opensearch-project/security-analytics/blob/main/src/main/config/rules/linux/auditd/lnx_auditd_screencaputre_xwd.yml"},"rule":{"name":"Screen Capture with Xwd","description":"Detects adversary creating screen capture of a full with xwd. Highly recommended using rule on servers, due high usage of screenshot utilities on user workstations","tags":["Rule Type: Sigma","Data Source: OpenSearch","Domain: Cloud","Tactic: Collection","Technique: T1113","OS: Linux","SIEM: OpenSearch"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"type\": \"EXECVE\",\n    \"a0\": \"xwd\"\n  },\n  \"xwd_root_window\": {\n    \"a1\": \"-root\",\n    \"a2\": \"-out\",\n    \"a3|endswith\": \".xwd\"\n  },\n  \"xwd_no_root_window\": {\n    \"a1\": \"-out\",\n    \"a2|endswith\": \".xwd\"\n  },\n  \"condition\": \"selection and 1 of xwd_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1113/T1113.md#atomic-test-3---x-windows-capture","https://linux.die.net/man/1/xwd"],"false_positives":["Legitimate use of screenshot utility"]}}},"__N_SSG":true}