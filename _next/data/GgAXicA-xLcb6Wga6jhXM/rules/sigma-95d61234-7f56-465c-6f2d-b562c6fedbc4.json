{"pageProps":{"rule":{"metadata":{"updated_date":"2023-03-09T00:00:00.000Z","creation_date":"2023-03-09T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_remove_package.yml"},"rule":{"name":"Linux Package Uninstall","description":"Detects linux package removal using builtin tools such as \"yum\", \"apt\", \"apt-get\" or \"dpkg\".","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1070","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_yum\": {\n    \"Image|endswith\": \"/yum\",\n    \"CommandLine|contains\": [\n      \"erase\",\n      \"remove\"\n    ]\n  },\n  \"selection_apt\": {\n    \"Image|endswith\": [\n      \"/apt\",\n      \"/apt-get\"\n    ],\n    \"CommandLine|contains\": [\n      \"remove\",\n      \"purge\"\n    ]\n  },\n  \"selection_dpkg\": {\n    \"Image|endswith\": \"/dpkg\",\n    \"CommandLine|contains\": [\n      \"--remove \",\n      \" -r \"\n    ]\n  },\n  \"selection_rpm\": {\n    \"Image|endswith\": \"/rpm\",\n    \"CommandLine|contains\": \" -e \"\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://sysdig.com/blog/mitre-defense-evasion-falco","https://www.tutorialspoint.com/how-to-install-a-software-on-linux-using-yum-command","https://linuxhint.com/uninstall_yum_package/","https://linuxhint.com/uninstall-debian-packages/"],"false_positives":["Administrator or administrator scripts might delete packages for several reasons (debugging, troubleshooting)."]}}},"__N_SSG":true}