{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-08T00:00:00.000Z","creation_date":"2020-10-08T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_local_account.yml"},"rule":{"name":"Local System Accounts Discovery - Linux","description":"Detects enumeration of local system accounts. This information can help adversaries determine which local accounts exist on a system to aid in follow-on behavior.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1087.001","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_1\": {\n    \"Image|endswith\": \"/lastlog\"\n  },\n  \"selection_2\": {\n    \"CommandLine|contains\": \"'x:0:'\"\n  },\n  \"selection_3\": {\n    \"Image|endswith\": [\n      \"/cat\",\n      \"/ed\",\n      \"/head\",\n      \"/more\",\n      \"/nano\",\n      \"/tail\",\n      \"/vi\",\n      \"/vim\",\n      \"/less\",\n      \"/emacs\",\n      \"/sqlite3\",\n      \"/makemap\"\n    ],\n    \"CommandLine|contains\": [\n      \"/etc/passwd\",\n      \"/etc/shadow\",\n      \"/etc/sudoers\",\n      \"/etc/spwd.db\",\n      \"/etc/pwd.db\",\n      \"/etc/master.passwd\"\n    ]\n  },\n  \"selection_4\": {\n    \"Image|endswith\": \"/id\"\n  },\n  \"selection_5\": {\n    \"Image|endswith\": \"/lsof\",\n    \"CommandLine|contains\": \"-u\"\n  },\n  \"condition\": \"1 of selection*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1087.001/T1087.001.md","https://my.f5.com/manage/s/article/K589","https://man.freebsd.org/cgi/man.cgi?pwd_mkdb"],"false_positives":["Legitimate administration activities"]}}},"__N_SSG":true}