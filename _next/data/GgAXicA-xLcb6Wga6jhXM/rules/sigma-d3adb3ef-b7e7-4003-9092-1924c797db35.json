{"pageProps":{"rule":{"metadata":{"updated_date":"2023-09-27T00:00:00.000Z","creation_date":"2023-09-27T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/cloud/aws/cloudtrail/aws_sso_idp_change.yml"},"rule":{"name":"AWS Identity Center Identity Provider Change","description":"Detects a change in the AWS Identity Center (FKA AWS SSO) identity provider.\nA change in identity provider allows an attacker to establish persistent access or escalate privileges via user impersonation.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","Technique: T1556","OS: Aws","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"eventSource\": [\n      \"sso-directory.amazonaws.com\",\n      \"sso.amazonaws.com\"\n    ],\n    \"eventName\": [\n      \"AssociateDirectory\",\n      \"DisableExternalIdPConfigurationForDirectory\",\n      \"DisassociateDirectory\",\n      \"EnableExternalIdPConfigurationForDirectory\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://docs.aws.amazon.com/singlesignon/latest/userguide/app-enablement.html","https://docs.aws.amazon.com/singlesignon/latest/userguide/sso-info-in-cloudtrail.html","https://docs.aws.amazon.com/service-authorization/latest/reference/list_awsiamidentitycentersuccessortoawssinglesign-on.html"],"false_positives":["Authorized changes to the AWS account's identity provider"]}}},"__N_SSG":true}