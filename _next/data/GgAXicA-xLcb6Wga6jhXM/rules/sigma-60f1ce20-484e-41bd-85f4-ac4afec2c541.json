{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-13T00:00:00.000Z","creation_date":"2020-10-13T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_gui_input_capture.yml"},"rule":{"name":"GUI Input Capture - macOS","description":"Detects attempts to use system dialog prompts to capture user credentials","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Collection","Technique: T1056.002","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_img\": {\n    \"Image|endswith\": \"/osascript\"\n  },\n  \"selection_cli_1\": {\n    \"CommandLine|contains|all\": [\n      \"-e\",\n      \"display\",\n      \"dialog\",\n      \"answer\"\n    ]\n  },\n  \"selection_cli_2\": {\n    \"CommandLine|contains\": [\n      \"admin\",\n      \"administrator\",\n      \"authenticate\",\n      \"authentication\",\n      \"credentials\",\n      \"pass\",\n      \"password\",\n      \"unlock\"\n    ]\n  },\n  \"condition\": \"all of selection_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1056.002/T1056.002.md","https://scriptingosx.com/2018/08/user-interaction-from-bash-scripts/"],"false_positives":["Legitimate administration tools and activities"]}}},"__N_SSG":true}