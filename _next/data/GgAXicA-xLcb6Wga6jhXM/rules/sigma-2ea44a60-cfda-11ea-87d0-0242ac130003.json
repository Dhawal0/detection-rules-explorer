{"pageProps":{"rule":{"metadata":{"updated_date":"2020-08-04T00:00:00.000Z","creation_date":"2020-08-04T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/web/webserver_generic/web_webshell_regeorg.yml"},"rule":{"name":"Webshell ReGeorg Detection Via Web Logs","description":"Certain strings in the uri_query field when combined with null referer and null user agent can indicate activity associated with the webshell ReGeorg.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","Technique: T1505.003","Domain: webserver","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"cs-uri-query|contains\": [\n      \"cmd=read\",\n      \"connect&target\",\n      \"cmd=connect\",\n      \"cmd=disconnect\",\n      \"cmd=forward\"\n    ]\n  },\n  \"filter\": {\n    \"cs-referer\": null,\n    \"cs-user-agent\": null,\n    \"cs-method\": \"POST\"\n  },\n  \"condition\": \"selection and filter\"\n}","reference":["https://community.rsa.com/community/products/netwitness/blog/2019/02/19/web-shells-and-netwitness-part-3","https://github.com/sensepost/reGeorg"],"false_positives":["Web applications that use the same URL parameters as ReGeorg"]}}},"__N_SSG":true}