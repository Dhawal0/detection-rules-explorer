{"pageProps":{"rule":{"metadata":{"updated_date":"2023-08-23T00:00:00.000Z","creation_date":"2023-08-23T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_susp_inod_listing.yml"},"rule":{"name":"Potential Container Discovery Via Inodes Listing","description":"Detects listing of the inodes of the \"/\" directory to determine if the we are running inside of a container.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1082","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_ls_img\": {\n    \"Image|endswith\": \"/ls\"\n  },\n  \"selection_ls_cli\": [\n    {\n      \"CommandLine|endswith\": \" /\"\n    },\n    {\n      \"CommandLine|contains\": \" / \"\n    }\n  ],\n  \"selection_regex_inode\": {\n    \"CommandLine|re\": \"(?:\\\\s-[^-\\\\s]{0,20}i|\\\\s--inode\\\\s)\"\n  },\n  \"selection_regex_dir\": {\n    \"CommandLine|re\": \"(?:\\\\s-[^-\\\\s]{0,20}d|\\\\s--directory\\\\s)\"\n  },\n  \"condition\": \"all of selection_*\"\n}","reference":["https://blog.skyplabs.net/posts/container-detection/","https://stackoverflow.com/questions/20010199/how-to-determine-if-a-process-runs-inside-lxc-docker"],"false_positives":["Legitimate system administrator usage of these commands","Some container tools or deployments may use these techniques natively to determine how they proceed with execution, and will need to be filtered"]}}},"__N_SSG":true}