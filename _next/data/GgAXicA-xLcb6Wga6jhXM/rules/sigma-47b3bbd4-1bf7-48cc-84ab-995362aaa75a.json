{"pageProps":{"rule":{"metadata":{"updated_date":"2024-09-02T00:00:00.000Z","creation_date":"2024-09-02T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_git_shell_execution.yml"},"rule":{"name":"Shell Execution via Git - Linux","description":"Detects the use of the \"git\" utility to execute a shell. Such behavior may be associated with privilege escalation, unauthorized command execution, or to break out from restricted environments.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","Technique: T1059","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"ParentImage|endswith\": \"/git\",\n    \"ParentCommandLine|contains|all\": [\n      \" -p \",\n      \"help\"\n    ],\n    \"CommandLine|contains\": [\n      \"bash 0<&1\",\n      \"dash 0<&1\",\n      \"sh 0<&1\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://gtfobins.github.io/gtfobins/git/#shell"],"false_positives":["Unknown"]}}},"__N_SSG":true}