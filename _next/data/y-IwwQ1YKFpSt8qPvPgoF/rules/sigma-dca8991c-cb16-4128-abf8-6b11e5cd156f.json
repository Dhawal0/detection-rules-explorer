{"pageProps":{"rule":{"metadata":{"updated_date":"2025-10-18T00:00:00.000Z","creation_date":"2025-10-18T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/application/github/audit/github_repository_archive_status_changed.yml"},"rule":{"name":"GitHub Repository Archive Status Changed","description":"Detects when a GitHub repository is archived or unarchived, which may indicate unauthorized changes to repository status.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","Tactic: Impact","OS: Github","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"action\": [\n      \"repo.archived\",\n      \"repo.unarchived\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://docs.github.com/en/repositories/archiving-a-github-repository/archiving-repositories","https://www.sentinelone.com/blog/exploiting-repos-6-ways-threat-actors-abuse-github-other-devops-platforms","https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/security-log-events"],"false_positives":["Archiving or unarchiving a repository is often legitimate. Investigate this action to determine if it was authorized."]}}},"__N_SSG":true}