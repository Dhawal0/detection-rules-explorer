{"pageProps":{"rule":{"metadata":{"updated_date":"2023-09-18T00:00:00.000Z","creation_date":"2023-09-18T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/cloud/m365/audit/microsoft365_new_federated_domain_added_audit.yml"},"rule":{"name":"New Federated Domain Added","description":"Detects the addition of a new Federated Domain.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1484.002","OS: M365","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection_domain\": {\n    \"Operation|contains\": \"domain\"\n  },\n  \"selection_operation\": {\n    \"Operation|contains\": [\n      \"add\",\n      \"new\"\n    ]\n  },\n  \"condition\": \"all of selection_*\"\n}","reference":["https://research.splunk.com/cloud/e155876a-6048-11eb-ae93-0242ac130002/","https://o365blog.com/post/aadbackdoor/"],"false_positives":["The creation of a new Federated domain is not necessarily malicious, however these events need to be followed closely, as it may indicate federated credential abuse or backdoor via federated identities at a similar or different cloud provider."]}}},"__N_SSG":true}