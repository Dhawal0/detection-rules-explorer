{"pageProps":{"rule":{"metadata":{"updated_date":"2021-10-15T00:00:00.000Z","creation_date":"2021-10-15T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_clipboard_collection.yml"},"rule":{"name":"Clipboard Collection with Xclip Tool","description":"Detects attempts to collect data stored in the clipboard from users with the usage of xclip tool. Xclip has to be installed.\nHighly recommended using rule on servers, due to high usage of clipboard utilities on user workstations.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Collection","Technique: T1115","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|contains\": \"xclip\",\n    \"CommandLine|contains|all\": [\n      \"-sel\",\n      \"clip\",\n      \"-o\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://www.packetlabs.net/posts/clipboard-data-security/"],"false_positives":["Legitimate usage of xclip tools."]}}},"__N_SSG":true}