{"pageProps":{"rule":{"metadata":{"updated_date":"2021-09-06T00:00:00.000Z","creation_date":"2021-09-06T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/auditd/execve/lnx_auditd_hidden_files_directories.yml"},"rule":{"name":"Hidden Files and Directories","description":"Detects adversary creating hidden file or directory, by detecting directories or files with . as the first character","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1564.001","OS: Linux","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_commands\": {\n    \"type\": \"EXECVE\",\n    \"a0\": [\n      \"mkdir\",\n      \"nano\",\n      \"touch\",\n      \"vi\",\n      \"vim\"\n    ]\n  },\n  \"selection_arguments\": [\n    {\n      \"a1|re\": \"(^|\\\\/)\\\\.[^.\\\\/]\"\n    },\n    {\n      \"a2|re\": \"(^|\\\\/)\\\\.[^.\\\\/]\"\n    }\n  ],\n  \"condition\": \"all of selection_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1564.001/T1564.001.md"],"false_positives":["Unknown"]}}},"__N_SSG":true}