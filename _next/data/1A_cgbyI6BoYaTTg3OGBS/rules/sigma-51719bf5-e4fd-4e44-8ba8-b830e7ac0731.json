{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-06T00:00:00.000Z","creation_date":"2020-10-06T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_create_account.yml"},"rule":{"name":"Creation Of A Local User Account","description":"Detects the creation of a new user account. Such accounts may be used for persistence that do not require persistent remote access tools to be deployed on the system.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1136.001","Tactic: Persistence","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection_dscl\": {\n    \"Image|endswith\": \"/dscl\",\n    \"CommandLine|contains\": \"create\"\n  },\n  \"selection_sysadminctl\": {\n    \"Image|endswith\": \"/sysadminctl\",\n    \"CommandLine|contains\": \"addUser\"\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1136.001/T1136.001.md","https://ss64.com/osx/sysadminctl.html"],"false_positives":["Legitimate administration activities"]}}},"__N_SSG":true}