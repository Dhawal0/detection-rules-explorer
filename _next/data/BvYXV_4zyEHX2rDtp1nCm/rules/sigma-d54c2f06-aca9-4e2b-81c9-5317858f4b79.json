{"pageProps":{"rule":{"metadata":{"updated_date":"2023-09-04T00:00:00.000Z","creation_date":"2023-09-04T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_esxcli_vsan_discovery.yml"},"rule":{"name":"ESXi VSAN Information Discovery Via ESXCLI","description":"Detects execution of the \"esxcli\" command with the \"vsan\" flag in order to retrieve information about virtual storage. Seen used by malware such as DarkSide.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Tactic: Execution","Technique: T1033","Technique: T1007","Technique: T1059.012","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection_img\": {\n    \"Image|endswith\": \"/esxcli\",\n    \"CommandLine|contains\": \"vsan\"\n  },\n  \"selection_cli\": {\n    \"CommandLine|contains\": [\n      \" get\",\n      \" list\"\n    ]\n  },\n  \"condition\": \"all of selection_*\"\n}","reference":["https://www.trendmicro.com/en_us/research/21/e/darkside-linux-vms-targeted.html","https://www.trendmicro.com/en_us/research/22/a/analysis-and-Impact-of-lockbit-ransomwares-first-linux-and-vmware-esxi-variant.html","https://developer.broadcom.com/xapis/esxcli-command-reference/7.0.0/namespace/esxcli_vsan.html"],"false_positives":["Legitimate administration activities"]}}},"__N_SSG":true}