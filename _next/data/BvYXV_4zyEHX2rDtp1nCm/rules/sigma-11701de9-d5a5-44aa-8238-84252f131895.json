{"pageProps":{"rule":{"metadata":{"updated_date":"2023-08-23T00:00:00.000Z","creation_date":"2023-08-23T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_susp_dockerenv_recon.yml"},"rule":{"name":"Docker Container Discovery Via Dockerenv Listing","description":"Detects listing or file reading of \".dockerenv\" which can be a sing of potential container discovery","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1082","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": [\n      \"/cat\",\n      \"/dir\",\n      \"/find\",\n      \"/ls\",\n      \"/stat\",\n      \"/test\",\n      \"grep\"\n    ],\n    \"CommandLine|endswith\": \".dockerenv\"\n  },\n  \"condition\": \"selection\"\n}","reference":["https://blog.skyplabs.net/posts/container-detection/","https://stackoverflow.com/questions/20010199/how-to-determine-if-a-process-runs-inside-lxc-docker"],"false_positives":["Legitimate system administrator usage of these commands","Some container tools or deployments may use these techniques natively to determine how they proceed with execution, and will need to be filtered"]}}},"__N_SSG":true}