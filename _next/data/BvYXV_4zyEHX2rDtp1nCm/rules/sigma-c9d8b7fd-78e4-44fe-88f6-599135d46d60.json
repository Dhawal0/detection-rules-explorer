{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-19T00:00:00.000Z","creation_date":"2020-10-19T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_security_software_discovery.yml"},"rule":{"name":"Security Software Discovery - Linux","description":"Detects usage of system utilities (only grep and egrep for now) to discover security software discovery","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1518.001","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": [\n      \"/grep\",\n      \"/egrep\"\n    ],\n    \"CommandLine|contains\": [\n      \"nessusd\",\n      \"td-agent\",\n      \"packetbeat\",\n      \"filebeat\",\n      \"auditbeat\",\n      \"osqueryd\",\n      \"cbagentd\",\n      \"falcond\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1518.001/T1518.001.md"],"false_positives":["Legitimate activities"]}}},"__N_SSG":true}