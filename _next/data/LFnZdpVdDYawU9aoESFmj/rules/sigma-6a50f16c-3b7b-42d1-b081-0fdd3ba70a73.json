{"pageProps":{"rule":{"metadata":{"updated_date":"2022-12-21T00:00:00.000Z","creation_date":"2022-12-21T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_usermod_susp_group.yml"},"rule":{"name":"User Added To Root/Sudoers Group Using Usermod","description":"Detects usage of the \"usermod\" binary to add users add users to the root or suoders groups","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": \"/usermod\",\n    \"CommandLine|contains\": [\n      \"-aG root\",\n      \"-aG sudoers\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://pberba.github.io/security/2021/11/23/linux-threat-hunting-for-persistence-account-creation-manipulation/","https://www.configserverfirewall.com/ubuntu-linux/ubuntu-add-user-to-root-group/"],"false_positives":["Legitimate administrator activities"]}}},"__N_SSG":true}