{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-19T00:00:00.000Z","creation_date":"2020-10-19T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_disable_security_tools.yml"},"rule":{"name":"Disable Security Tools","description":"Detects disabling security tools","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1685","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"launchctl_unload\": {\n    \"Image\": \"/bin/launchctl\",\n    \"CommandLine|contains\": \"unload\"\n  },\n  \"security_plists\": {\n    \"CommandLine|contains\": [\n      \"com.objective-see.lulu.plist\",\n      \"com.objective-see.blockblock.plist\",\n      \"com.google.santad.plist\",\n      \"com.carbonblack.defense.daemon.plist\",\n      \"com.carbonblack.daemon.plist\",\n      \"at.obdev.littlesnitchd.plist\",\n      \"com.tenablesecurity.nessusagent.plist\",\n      \"com.opendns.osx.RoamingClientConfigUpdater.plist\",\n      \"com.crowdstrike.falcond.plist\",\n      \"com.crowdstrike.userdaemon.plist\",\n      \"osquery\",\n      \"filebeat\",\n      \"auditbeat\",\n      \"packetbeat\",\n      \"td-agent\"\n    ]\n  },\n  \"disable_gatekeeper\": {\n    \"Image\": \"/usr/sbin/spctl\",\n    \"CommandLine|contains\": \"disable\"\n  },\n  \"condition\": \"(launchctl_unload and security_plists) or disable_gatekeeper\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1562.001/T1562.001.md"],"false_positives":["Legitimate activities"]}}},"__N_SSG":true}