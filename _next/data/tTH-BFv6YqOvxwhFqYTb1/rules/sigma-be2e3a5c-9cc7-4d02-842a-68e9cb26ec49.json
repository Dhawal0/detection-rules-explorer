{"pageProps":{"rule":{"metadata":{"updated_date":"2023-08-22T00:00:00.000Z","creation_date":"2023-08-22T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_jamf_usage.yml"},"rule":{"name":"JAMF MDM Execution","description":"Detects execution of the \"jamf\" binary to create user accounts and run commands. For example, the binary can be abused by attackers on the system in order to bypass security controls or remove application control polices.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"low","risk_score":21,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": \"/jamf\",\n    \"CommandLine|contains\": [\n      \"createAccount\",\n      \"manage\",\n      \"removeFramework\",\n      \"removeMdmProfile\",\n      \"resetPassword\",\n      \"setComputerName\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://github.com/MythicAgents/typhon/","https://www.zoocoup.org/casper/jamf_cheatsheet.pdf","https://docs.jamf.com/10.30.0/jamf-pro/administrator-guide/Components_Installed_on_Managed_Computers.html"],"false_positives":["Legitimate use of the JAMF CLI tool by IT support and administrators"]}}},"__N_SSG":true}