{"pageProps":{"rule":{"metadata":{"updated_date":"2026-06-26T22:32:05.000Z","source_siem":"OpenSearch","source_siem_id":"opensearch","source_url":"https://github.com/opensearch-project/security-analytics/blob/main/src/main/config/rules/linux/auditd/lnx_auditd_systemd_service_creation.yml"},"rule":{"name":"Systemd Service Creation","description":"Detects a creation of systemd services which could be used by adversaries to execute malicious code.","tags":["Rule Type: Sigma","Data Source: OpenSearch","Domain: Cloud","Tactic: Persistence","Technique: T1543.002","OS: Linux","SIEM: OpenSearch"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"path\": {\n    \"type\": \"PATH\",\n    \"nametype\": \"CREATE\"\n  },\n  \"name_1\": {\n    \"name|startswith\": [\n      \"/usr/lib/systemd/system/\",\n      \"/etc/systemd/system/\"\n    ]\n  },\n  \"name_2\": {\n    \"name|contains\": \"/.config/systemd/user/\"\n  },\n  \"condition\": \"path and 1 of name_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1543.002/T1543.002.md"],"false_positives":["Admin work like legit service installs."]}}},"__N_SSG":true}