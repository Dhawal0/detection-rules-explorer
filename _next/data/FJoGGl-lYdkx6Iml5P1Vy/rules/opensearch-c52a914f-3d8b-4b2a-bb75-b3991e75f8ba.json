{"pageProps":{"rule":{"metadata":{"updated_date":"2026-05-21T23:24:42.000Z","source_siem":"OpenSearch","source_siem_id":"opensearch","source_url":"https://github.com/opensearch-project/security-analytics/blob/main/src/main/config/rules/linux/auditd/lnx_auditd_binary_padding.yml"},"rule":{"name":"Binary Padding - Linux","description":"Adversaries may use binary padding to add junk data and change the on-disk representation of malware.\nThis rule detect using dd and truncate to add a junk data to file.\n","tags":["Rule Type: Sigma","Data Source: OpenSearch","Domain: Cloud","Tactic: Defense Evasion","Technique: T1027.001","OS: Linux","SIEM: OpenSearch"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection_execve\": {\n    \"type\": \"EXECVE\"\n  },\n  \"keywords_truncate\": {\n    \"|all\": [\n      \"truncate\",\n      \"-s\"\n    ]\n  },\n  \"keywords_dd\": {\n    \"|all\": [\n      \"dd\",\n      \"if=\"\n    ]\n  },\n  \"keywords_filter\": [\n    \"of=\"\n  ],\n  \"condition\": \"selection_execve and (keywords_truncate or (keywords_dd and not keywords_filter))\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1027.001/T1027.001.md"],"false_positives":["Unknown"]}}},"__N_SSG":true}