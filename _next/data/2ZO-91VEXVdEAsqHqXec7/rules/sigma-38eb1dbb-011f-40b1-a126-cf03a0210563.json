{"pageProps":{"rule":{"metadata":{"updated_date":"2023-09-04T00:00:00.000Z","creation_date":"2023-09-04T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_esxcli_syslog_config_change.yml"},"rule":{"name":"ESXi Syslog Configuration Change Via ESXCLI","description":"Detects changes to the ESXi syslog configuration via \"esxcli\"","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","Technique: T1685","Technique: T1690","Technique: T1059.012","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"Image|endswith\": \"/esxcli\",\n    \"CommandLine|contains|all\": [\n      \"system\",\n      \"syslog\",\n      \"config\"\n    ],\n    \"CommandLine|contains\": \" set\"\n  },\n  \"condition\": \"selection\"\n}","reference":["https://support.solarwinds.com/SuccessCenter/s/article/Configure-ESXi-Syslog-to-LEM?language=en_US","https://developer.broadcom.com/xapis/esxcli-command-reference/7.0.0/namespace/esxcli_system.html"],"false_positives":["Legitimate administrative activities"]}}},"__N_SSG":true}