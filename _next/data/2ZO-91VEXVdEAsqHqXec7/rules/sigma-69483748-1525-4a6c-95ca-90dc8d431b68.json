{"pageProps":{"rule":{"metadata":{"updated_date":"2023-01-31T00:00:00.000Z","creation_date":"2023-01-31T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_office_susp_child_processes.yml"},"rule":{"name":"Suspicious Microsoft Office Child Process - MacOS","description":"Detects suspicious child processes spawning from microsoft office suite applications such as word or excel. This could indicates malicious macro execution","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","Tactic: Persistence","Technique: T1059.002","Technique: T1137.002","Technique: T1204.002","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"ParentImage|contains\": [\n      \"Microsoft Word\",\n      \"Microsoft Excel\",\n      \"Microsoft PowerPoint\",\n      \"Microsoft OneNote\"\n    ],\n    \"Image|endswith\": [\n      \"/bash\",\n      \"/curl\",\n      \"/dash\",\n      \"/fish\",\n      \"/osacompile\",\n      \"/osascript\",\n      \"/sh\",\n      \"/zsh\",\n      \"/python\",\n      \"/python3\",\n      \"/wget\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["https://redcanary.com/blog/applescript/","https://objective-see.org/blog/blog_0x4B.html"],"false_positives":["Unknown"]}}},"__N_SSG":true}