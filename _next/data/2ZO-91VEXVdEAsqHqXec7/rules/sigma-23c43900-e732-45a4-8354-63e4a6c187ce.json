{"pageProps":{"rule":{"metadata":{"updated_date":"2020-10-23T00:00:00.000Z","creation_date":"2020-10-23T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/file_event/file_event_macos_emond_launch_daemon.yml"},"rule":{"name":"MacOS Emond Launch Daemon","description":"Detects additions to the Emond Launch Daemon that adversaries may use to gain persistence and elevate privileges.","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Persistence","Technique: T1546.014","OS: Macos","Domain: file event","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection_1\": {\n    \"TargetFilename|contains\": \"/etc/emond.d/rules/\",\n    \"TargetFilename|endswith\": \".plist\"\n  },\n  \"selection_2\": {\n    \"TargetFilename|contains\": \"/private/var/db/emondClients/\"\n  },\n  \"condition\": \"1 of selection_*\"\n}","reference":["https://github.com/redcanaryco/atomic-red-team/blob/f339e7da7d05f6057fdfcdd3742bfcf365fee2a9/atomics/T1546.014/T1546.014.md","https://posts.specterops.io/leveraging-emond-on-macos-for-persistence-a040a2785124"],"false_positives":["Legitimate administration activities"]}}},"__N_SSG":true}