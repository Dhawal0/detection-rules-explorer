{"pageProps":{"rule":{"metadata":{"updated_date":"2022-03-14T00:00:00.000Z","creation_date":"2022-03-14T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_susp_interactive_bash.yml"},"rule":{"name":"Interactive Bash Suspicious Children","description":"Detects suspicious interactive bash as a parent to rather uncommon child processes","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Execution","Technique: T1059.004","Technique: T1036","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"ParentCommandLine\": \"bash -i\"\n  },\n  \"anomaly1\": {\n    \"CommandLine|contains\": [\n      \"-c import \",\n      \"base64\",\n      \"pty.spawn\"\n    ]\n  },\n  \"anomaly2\": {\n    \"Image|endswith\": [\n      \"whoami\",\n      \"iptables\",\n      \"/ncat\",\n      \"/nc\",\n      \"/netcat\"\n    ]\n  },\n  \"condition\": \"selection and 1 of anomaly*\"\n}","reference":["Internal Research"],"false_positives":["Legitimate software that uses these patterns"]}}},"__N_SSG":true}