{"pageProps":{"rule":{"metadata":{"updated_date":"2023-01-31T00:00:00.000Z","creation_date":"2023-01-31T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/macos/process_creation/proc_creation_macos_jxa_in_memory_execution.yml"},"rule":{"name":"JXA In-memory Execution Via OSAScript","description":"Detects possible malicious execution of JXA in-memory via OSAScript","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1059.002","Technique: T1059.007","Tactic: Execution","OS: Macos","Domain: process creation","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection_main\": {\n    \"CommandLine|contains|all\": [\n      \"osascript\",\n      \" -e \",\n      \"eval\",\n      \"NSData.dataWithContentsOfURL\"\n    ]\n  },\n  \"selection_js\": [\n    {\n      \"CommandLine|contains|all\": [\n        \" -l \",\n        \"JavaScript\"\n      ]\n    },\n    {\n      \"CommandLine|contains\": \".js\"\n    }\n  ],\n  \"condition\": \"all of selection_*\"\n}","reference":["https://redcanary.com/blog/applescript/"],"false_positives":["Unknown"]}}},"__N_SSG":true}