{"pageProps":{"rule":{"metadata":{"updated_date":"2018-01-23T00:00:00.000Z","creation_date":"2018-01-23T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/auditd/syscall/lnx_auditd_susp_exe_folders.yml"},"rule":{"name":"Program Executions in Suspicious Folders","description":"Detects program executions in suspicious non-program folders related to malware or hacking activity","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Technique: T1587","Technique: T1584","OS: Linux","SIEM: Sigma"],"severity":"medium","risk_score":47,"type":"sigma","language":"sigma","query":"{\n  \"selection\": {\n    \"type\": \"SYSCALL\",\n    \"exe|startswith\": [\n      \"/tmp/\",\n      \"/var/www/\",\n      \"/home/*/public_html/\",\n      \"/usr/local/apache2/\",\n      \"/usr/local/httpd/\",\n      \"/var/apache/\",\n      \"/srv/www/\",\n      \"/home/httpd/html/\",\n      \"/srv/http/\",\n      \"/usr/share/nginx/html/\",\n      \"/var/lib/pgsql/data/\",\n      \"/usr/local/mysql/data/\",\n      \"/var/lib/mysql/\",\n      \"/var/vsftpd/\",\n      \"/etc/bind/\",\n      \"/var/named/\"\n    ]\n  },\n  \"condition\": \"selection\"\n}","reference":["Internal Research"],"false_positives":["Admin activity (especially in /tmp folders)","Crazy web applications"]}}},"__N_SSG":true}