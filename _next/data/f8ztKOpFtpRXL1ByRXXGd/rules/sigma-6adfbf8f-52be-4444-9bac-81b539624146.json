{"pageProps":{"rule":{"metadata":{"updated_date":"2024-09-02T00:00:00.000Z","creation_date":"2024-09-02T00:00:00.000Z","source_siem":"Sigma","source_siem_id":"sigma","source_url":"https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_find_shell_execution.yml"},"rule":{"name":"Shell Execution via Find - Linux","description":"Detects the use of the find command to execute a shell. Such behavior may be associated with privilege escalation, unauthorized command execution, or exploitation attempt.\n","tags":["Rule Type: Sigma","Data Source: Cross-SIEM","Tactic: Discovery","Technique: T1083","OS: Linux","Domain: process creation","SIEM: Sigma"],"severity":"high","risk_score":73,"type":"sigma","language":"sigma","query":"{\n  \"selection_img\": {\n    \"Image|endswith\": \"/find\",\n    \"CommandLine|contains|all\": [\n      \" . \",\n      \"-exec\"\n    ]\n  },\n  \"selection_cli\": {\n    \"CommandLine|contains\": [\n      \"/bin/bash\",\n      \"/bin/dash\",\n      \"/bin/fish\",\n      \"/bin/sh\",\n      \"/bin/zsh\"\n    ]\n  },\n  \"condition\": \"all of selection_*\"\n}","reference":["https://gtfobins.github.io/gtfobins/find/#shell","https://www.elastic.co/guide/en/security/current/linux-restricted-shell-breakout-via-linux-binary-s.html"],"false_positives":["Unknown"]}}},"__N_SSG":true}